PORT=8080
MONGO_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/edubase
MONGO_DB=edubase-main
JWT_ACCESS_SECRET=change-me-access-secret-please
JWT_REFRESH_SECRET=change-me-refresh-secret-please
ACCESS_TTL=15m
REFRESH_TTL=168h
FRONTEND_ORIGIN=http://localhost:3000
# Prod'da subdomenlar uchun: .edubase.uz (lokalda bo'sh qoldiring)
COOKIE_DOMAIN=

# AWS S3 (avatar / fayl saqlash)
AWS_REGION=eu-central-1
AWS_S3_BUCKET=your-bucket-name
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
